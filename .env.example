# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Domain-restricted login (Workspace SSO-style). Users on this domain are admins.
ALLOWED_EMAIL_DOMAIN=yourcompany.com

# Auth enforcement (set false for local dev without login)
AUTH_ENFORCED=true
AUTH_COOKIE_SECURE=false

# JWT & encryption (change in production!)
JWT_SECRET=dev-secret-change-in-production-min-32-chars!!
ENCRYPTION_KEY=dev-encryption-key-32bytes-long!!!!

# Database
APP_DB_URL=jdbc:postgresql://localhost:5432/migration_app
APP_DB_USER=migration
APP_DB_PASSWORD=migration

# Lab playground DB (separate from platform migration_app)
LAB_DB_URL=jdbc:postgresql://localhost:5433/migration_lab
LAB_DB_USER=migration
LAB_DB_PASSWORD=migration

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Google Chat (GSpace) webhook
GSPACE_WEBHOOK_URL=

# Worker
WORKER_ID=worker-1
# API fetches worker Actuator metrics from this URL (server-side only)
WORKER_METRICS_URL=http://localhost:8081
# Shared by API + Worker — bundled/ + installed/ connector JARs
PLUGINS_DIR=./data/plugins

# App config seeds (written to DB on first boot; dashboard edits persist)
MIN_THREADS_PER_JOB=1
MAX_THREADS_PER_JOB=8
# IP whitelist: OPEN or RESTRICTED (JSON array of IPs/CIDRs) — editable in Settings
IP_WHITELIST_MODE=OPEN
IP_WHITELIST=[]

# Set true to force-overwrite DB config from env on startup (dev only)
APP_CONFIG_FORCE_ENV=false
